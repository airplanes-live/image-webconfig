[Unit]
Description=airplanes.live webconfig password reset
Documentation=https://github.com/airplanes-live/image
ConditionPathExists=/boot/firmware/airplanes-reset-password
DefaultDependencies=no
After=local-fs.target
Before=airplanes-webconfig.service

[Service]
Type=oneshot
ExecStart=/usr/local/lib/airplanes-webconfig/reset
RemainAfterExit=no

[Install]
WantedBy=airplanes-webconfig.service
