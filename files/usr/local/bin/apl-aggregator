#!/bin/bash
# apl-aggregator — privileged management of third-party feed aggregators
# (FlightRadar24, FlightAware, ...) that a feeder may optionally feed in
# addition to airplanes.live.
#
# Invoked by airplanes-webconfig via a fixed sudoers argv
# (`sudo -n /usr/local/bin/apl-aggregator <verb> --json`). Emits exactly one
# JSON envelope on stdout. Exit codes follow the apl-wifi / apl-feed contract:
#
#   0  ok
#   2  rejected (unknown id / invalid field value)
#   3  filesystem_error / state_error
#   4  lock_timeout
#   5  usage_error / parse_error
#
# Read verbs (status, list) take no stdin and emit {protocol_version,
# aggregators:[...]}. Mutating verbs (enable, set, disable, reset) read a JSON
# request object on stdin and emit {protocol_version, result:"ok", id} on
# success. enable additionally takes {lat, lon, alt, fields:{…}} and, for a
# vendor-installer adapter, fetches the pinned vendor binary on demand. export
# emits a backup blob with identities (incl. secret values — the one verb that
# does); import seeds identities from such a blob (enabled=false; refuses an
# enabled adapter).
#
# Adapter descriptors are trusted, code-owned data sourced from AGG_DESC_DIR —
# never loaded from /etc, never user-editable. Adapter ids are validated
# against AGG_ID_RE and must match their descriptor filename before any path
# interpolation. Per-adapter secret values (e.g. an FR24 sharing key) are read
# only via jq stdin, never passed on argv (which `/proc/<pid>/cmdline` exposes).
#
# Test seams (default to production paths/commands; stripped by sudo env_reset
# in production, same posture as apl-wifi's APL_WIFI_* seams):
#   AGG_STATE_DIR      per-adapter JSON state dir
#   AGG_INSTALL_ROOT   on-demand vendor binary install root
#   AGG_DESC_DIR       descriptor directory
#   AGG_SYSTEMCTL      systemctl binary
#   AGG_DECODER_ADDR   local readsb BEAST endpoint
#   AGG_DECODER_STATE  "up"/"down" to bypass the TCP probe in tests
#   AGG_STATE_HOME     vendor runtime/config home (e.g. fr24feed.ini)
#   AGG_FR24_BIN / AGG_FR24_INI         installed-binary / ini paths (enable)
#   AGG_FR24_ACQUIRE_OVERRIDE <dest>    stub the .deb fetch+extract in tests
#   AGG_FR24_SIGNUP_OVERRIDE <ini> <email>  stub the signup wizard in tests

set -Eeuo pipefail

AGG_STATE_DIR="${AGG_STATE_DIR:-/etc/airplanes/aggregators}"
AGG_INSTALL_ROOT="${AGG_INSTALL_ROOT:-/opt/airplanes-aggregators}"
AGG_DESC_DIR="${AGG_DESC_DIR:-/usr/local/lib/airplanes-webconfig/aggregators}"
AGG_SYSTEMCTL="${AGG_SYSTEMCTL:-systemctl}"
AGG_DECODER_ADDR="${AGG_DECODER_ADDR:-127.0.0.1:30005}"
AGG_LOCK="${AGG_LOCK:-/run/airplanes/aggregator.lock}"
AGG_LOCK_TIMEOUT="${AGG_LOCK_TIMEOUT:-5}"
AGG_STATE_HOME="${AGG_STATE_HOME:-/var/lib/airplanes-aggregators}"

# --- async-enable seams ----------------------------------------------------
# enable is fire-and-forget: cmd_enable validates synchronously then launches a
# detached worker via systemd-run, returning {result:"accepted"} in <1s. The
# worker (a second invocation of this script in __enable-worker mode) does the
# slow vendor acquire/signup and reports progress through AGG_ENABLE_STATE.
AGG_SYSTEMD_RUN="${AGG_SYSTEMD_RUN:-systemd-run}"  # test seam: stub to run the worker inline
AGG_ENABLE_UNIT="${AGG_ENABLE_UNIT:-airplanes-aggregator-enable.service}"
AGG_REQ_DIR="${AGG_REQ_DIR:-/run/airplanes/aggregator-req}"      # 0700 root; secret request spool
AGG_ENABLE_STATE="${AGG_ENABLE_STATE:-/run/airplanes/aggregator-enable.state}"  # async progress overlay
AGG_ENABLE_GRACE="${AGG_ENABLE_GRACE:-10}"  # secs before a unit-less running overlay is reconciled to failed
AGG_SELF="${AGG_SELF:-/usr/local/bin/apl-aggregator}"  # worker binary path for systemd-run

readonly AGG_PROTOCOL_VERSION=1
readonly AGG_ID_RE='^[a-z0-9][a-z0-9_-]*$'
readonly AGG_STATE_MAX_BYTES=65536
readonly AGG_STATE_SCHEMA_VERSION=1

# WORKER_MODE=1 reroutes _emit_error/_emit_ok to the AGG_ENABLE_STATE progress
# file instead of stdout (the worker has no HTTP caller). Set by __enable-worker.
WORKER_MODE=0
WORKER_ID=""        # adapter id the worker is enabling (for the progress overlay)
WORKER_REQID=""     # request_id of the in-flight enable
WORKER_STARTED=0    # epoch secs the enable was launched (for grace-window reconciliation)
WORKER_STEP=""      # current phase label written into the overlay

# --- output helpers --------------------------------------------------------

_emitted=0

_emit_json() {
	_emitted=1
	printf '%s\n' "$1"
}

_emit_error() {
	local code="$1" message="$2" body
	# In worker mode there is no HTTP caller: record the failure in the async
	# progress overlay instead of printing an envelope to stdout. The existing
	# _enable_fr24 `_emit_error …; exit N` call sites thus become progress
	# writes with no change to that function.
	if (( WORKER_MODE == 1 )); then
		_write_enable_state failed "$code" "$message"
		_emitted=1
		return
	fi
	if ! body="$(jq -nc \
		--argjson pv "$AGG_PROTOCOL_VERSION" --arg c "$code" --arg m "$message" \
		'{protocol_version:$pv, result:"error", error_code:$c, message:$m}')"; then
		printf '{"protocol_version":%d,"result":"error","error_code":"%s","message":"jq emit failed"}\n' \
			"$AGG_PROTOCOL_VERSION" "$code"
		_emitted=1
		return
	fi
	_emit_json "$body"
}

# Last-resort envelope if the script exits without having emitted anything
# (e.g. an unexpected error under `set -e`). Keeps the JSON contract — callers
# always get one parseable object — and normalizes the process exit to 3
# (state_error) so an errexit-propagated 1/127 can't masquerade as some other
# contract code.
# shellcheck disable=SC2317  # invoked indirectly via `trap _on_exit EXIT`
_on_exit() {
	local rc=$?
	if (( _emitted != 0 )); then
		return
	fi
	if (( WORKER_MODE == 1 )); then
		# The worker died without writing a terminal state (e.g. errexit on an
		# unexpected failure). Record a generic failure so status reconciles to
		# failed instead of hanging on "installing". A SIGKILL/RuntimeMaxSec
		# bypasses this trap entirely; status's grace+unit-liveness check is the
		# backstop for that.
		_write_enable_state failed state_error "apl-aggregator worker: unexpected error (exit $rc)"
		_emitted=1
		return
	fi
	printf '{"protocol_version":%d,"result":"error","error_code":"state_error","message":"apl-aggregator: unexpected error (exit %d)"}\n' \
		"$AGG_PROTOCOL_VERSION" "$rc"
	exit 3
}
trap _on_exit EXIT

# --- async-enable progress overlay -----------------------------------------

# _write_enable_state <status> [error_code] [message]: atomically write the
# async progress overlay for the in-flight enable. status ∈
# starting|running|done|failed; step is the current phase. Mode 0600 root.
# WORKER_ID/WORKER_REQID identify the adapter; in the synchronous launch path
# cmd_enable sets them before the first write.
_write_enable_state() {
	local status="$1" code="${2-}" message="${3-}" step="${WORKER_STEP:-$1}" tmp body
	install -d -m 0755 "$(dirname "$AGG_ENABLE_STATE")" 2>/dev/null || true
	body="$(jq -nc \
		--argjson pv "$AGG_PROTOCOL_VERSION" --arg id "$WORKER_ID" --arg rid "$WORKER_REQID" \
		--argjson started "${WORKER_STARTED:-0}" \
		--arg st "$status" --arg step "$step" --arg c "$code" --arg m "$message" \
		'{protocol_version:$pv, id:$id, request_id:$rid, started_at:$started, status:$st, step:$step}
		 | (if $c != "" then .error_code = $c else . end)
		 | (if $m != "" then .message = $m else . end)' 2>/dev/null)" || return 0
	tmp="$(mktemp "${AGG_ENABLE_STATE}.XXXXXX" 2>/dev/null)" || return 0
	if printf '%s\n' "$body" >"$tmp" 2>/dev/null && chmod 0600 "$tmp" 2>/dev/null; then
		mv -f "$tmp" "$AGG_ENABLE_STATE" 2>/dev/null || rm -f -- "$tmp"
	else
		rm -f -- "$tmp"
	fi
}

# _clear_enable_state <id> [reqid]: drop the overlay if it belongs to id (so
# disable / reset / a fresh enable don't leave a stale failed/running overlay
# shadowing the adapter). When reqid is given, clear only if it also matches —
# so a rolled-back launch removes its OWN overlay, never one a concurrent enable
# just published. A no-op if the overlay is for another adapter / request.
_clear_enable_state() {
	local id="$1" reqid="${2-}" raw oid orid
	[[ -f "$AGG_ENABLE_STATE" ]] || return 0
	raw="$(head -c "$AGG_STATE_MAX_BYTES" "$AGG_ENABLE_STATE" 2>/dev/null || true)"
	oid="$(jq -r '.id // ""' <<<"$raw" 2>/dev/null || true)"
	[[ "$oid" == "$id" ]] || return 0
	if [[ -n "$reqid" ]]; then
		orid="$(jq -r '.request_id // ""' <<<"$raw" 2>/dev/null || true)"
		[[ "$orid" == "$reqid" ]] || return 0
	fi
	rm -f -- "$AGG_ENABLE_STATE"
	return 0
}

# _enable_overlay <id>: echo the overlay JSON for id (reconciled), or empty.
# A status:"running" overlay whose unit is no longer active/activating AND
# whose started_at is past the grace window is reconciled to failed (the worker
# died without writing terminal state). The reconciliation is computed
# read-only and NOT written back: this runs under `status`, which holds no
# lock, so persisting here could clobber a fresh overlay a concurrent enable
# just published. The result is deterministic anyway — a --collect'd dead unit
# never returns to active — so status reports failed consistently, and the next
# lock-holding verb (enable/disable/reset) clears the stale file.
_enable_overlay() {
	local id="$1" raw oid status
	[[ -f "$AGG_ENABLE_STATE" ]] || return 0
	raw="$(head -c "$AGG_STATE_MAX_BYTES" "$AGG_ENABLE_STATE" 2>/dev/null || true)"
	jq -e 'type == "object"' >/dev/null 2>&1 <<<"$raw" || return 0
	oid="$(jq -r '.id // ""' <<<"$raw")"
	[[ "$oid" == "$id" ]] || return 0
	status="$(jq -r '.status // ""' <<<"$raw")"
	if [[ "$status" == "running" || "$status" == "starting" ]]; then
		local svc
		svc="$(_service_state "$AGG_ENABLE_UNIT")"
		if [[ "$svc" != "active" && "$svc" != "activating" ]]; then
			# Worker not running. Within the grace window it may simply not have
			# been observed by systemd yet; past it, treat as a dead worker.
			local started age
			started="$(jq -r '.started_at // 0' <<<"$raw")"
			[[ "$started" =~ ^[0-9]+$ ]] || started=0
			age=$(( $(date +%s 2>/dev/null || echo 0) - started ))
			if (( started > 0 && age > AGG_ENABLE_GRACE )); then
				raw="$(jq -c '.status = "failed"
					| .error_code = (.error_code // "state_error")
					| .message = (.message // "enable worker stopped unexpectedly")' <<<"$raw")"
			fi
		fi
	fi
	printf '%s' "$raw"
}

# --- probes ----------------------------------------------------------------

# _decoder_reachable: does the local readsb BEAST endpoint accept a connection?
# host/port are passed as positional args to a single-quoted inner script so a
# malformed AGG_DECODER_ADDR can never inject into the root shell.
_decoder_reachable() {
	case "${AGG_DECODER_STATE:-}" in
		up) return 0 ;;
		down) return 1 ;;
	esac
	local host="${AGG_DECODER_ADDR%%:*}" port="${AGG_DECODER_ADDR##*:}"
	[[ -n "$host" && "$port" =~ ^[0-9]+$ ]] || return 1
	# $1/$2 are the inner bash's positional args (host/port), expanded at its
	# runtime — deliberately single-quoted so the outer shell does not interpolate.
	# shellcheck disable=SC2016
	timeout 1 bash -c 'exec 3<>/dev/tcp/"$1"/"$2"' _ "$host" "$port" 2>/dev/null
}

# _service_state: the trimmed `systemctl is-active` word for a unit. is-active
# exits non-zero for any non-active state, so the error is expected; the stdout
# word is authoritative.
_service_state() {
	local unit="$1" out
	out="$("$AGG_SYSTEMCTL" is-active "$unit" 2>/dev/null || true)"
	out="${out//[$'\t\r\n ']/}"
	if [[ -n "$out" ]]; then printf '%s' "$out"; else printf 'unknown'; fi
}

# _derive_state: availability + service state + persisted/install facts ->
# reported lifecycle state. Mirrors the documented status enum.
_derive_state() {
	local available="$1" svc="$2" enabled="$3" installed="$4"
	if [[ "$available" != "true" ]]; then printf 'unavailable'; return; fi
	case "$svc" in
		active) printf 'running'; return ;;
		failed) printf 'failed'; return ;;
	esac
	if [[ "$enabled" == "true" || "$installed" == "true" ]]; then
		printf 'stopped'
	else
		printf 'not_installed'
	fi
}

# --- status ----------------------------------------------------------------

# _adapter_json <desc_file> <decoder_json> -> one compact JSON status object.
# Sourced descriptor vars are isolated in a subshell so adapters can't leak
# into one another. Exits non-zero on a malformed descriptor (a code/ship bug);
# the caller turns that into a loud state_error rather than silently dropping
# the adapter.
_adapter_json() {
	local desc_file="$1" decoder_json="$2"
	(
		AGG_ID=""; AGG_DISPLAY_NAME=""; AGG_ACQUIRE_METHOD=""
		AGG_SERVICE_UNIT=""; AGG_MLAT_CAPABLE="false"; AGG_MLAT_DEFAULT="false"
		AGG_CLAIM_URL=""; AGG_SECRET_FIELDS=""; AGG_FIELDS_JSON="[]"
		# shellcheck source=/dev/null
		source "$desc_file"

		# id must be syntactically valid AND match the filename (also dedups,
		# since filenames are unique within a directory).
		local base
		base="$(basename "$desc_file" .desc)"
		[[ "$AGG_ID" =~ $AGG_ID_RE && "$AGG_ID" == "$base" ]] || {
			printf 'apl-aggregator: descriptor id %q != filename %q (%s)\n' "$AGG_ID" "$base" "$desc_file" >&2
			exit 1
		}
		[[ -n "$AGG_DISPLAY_NAME" && -n "$AGG_ACQUIRE_METHOD" && -n "$AGG_SERVICE_UNIT" ]] || {
			printf 'apl-aggregator: descriptor %s missing required field(s)\n' "$desc_file" >&2
			exit 1
		}
		# AGG_FIELDS_JSON is spliced verbatim into output; it must be valid JSON.
		jq -e . >/dev/null 2>&1 <<<"$AGG_FIELDS_JSON" || {
			printf 'apl-aggregator: descriptor %s has invalid AGG_FIELDS_JSON\n' "$desc_file" >&2
			exit 1
		}

		local available reason
		if [[ "$AGG_ACQUIRE_METHOD" == "vendor-installer" ]]; then
			available="true"; reason=""
		else
			available="false"; reason="not yet supported on this device"
		fi

		# State is JSON, parsed (never sourced) and size-capped. Strict typing:
		# booleans must be literal true; a non-object document or non-object
		# .fields degrades to "not configured" rather than failing the report
		# (runtime data may be transiently corrupt — distinct from a descriptor
		# bug, which fails loud above).
		local raw='{}' enabled="false" mlat_enabled="false"
		local state_path="$AGG_STATE_DIR/$AGG_ID.json"
		if [[ -f "$state_path" ]]; then
			local file_raw
			file_raw="$(head -c "$AGG_STATE_MAX_BYTES" "$state_path" 2>/dev/null || true)"
			if jq -e 'type == "object"' >/dev/null 2>&1 <<<"$file_raw"; then
				raw="$file_raw"
				enabled="$(jq -r '.enabled == true' <<<"$raw")"
				mlat_enabled="$(jq -r '.mlat_enabled == true' <<<"$raw")"
			fi
		fi

		# installed = the on-demand vendor dir exists AND is non-empty. A bare
		# (partially-extracted or pre-created) directory must not read as
		# installed, or a failed acquire would surface as "stopped" instead of
		# "not_installed".
		local installed="false"
		if [[ "$AGG_ACQUIRE_METHOD" == "vendor-installer" && -d "$AGG_INSTALL_ROOT/$AGG_ID" \
			&& -n "$(ls -A "$AGG_INSTALL_ROOT/$AGG_ID" 2>/dev/null)" ]]; then
			installed="true"
		fi

		local state
		state="$(_derive_state "$available" "$(_service_state "$AGG_SERVICE_UNIT")" "$enabled" "$installed")"

		# Async-enable overlay: an in-flight or recently-failed enable for this
		# adapter takes precedence over the service-derived state, so the UI can
		# show installing/failed with progress while the detached worker runs.
		local overlay ov_json="null" ov_status
		if overlay="$(_enable_overlay "$AGG_ID")" && [[ -n "$overlay" ]]; then
			ov_json="$overlay"
			ov_status="$(jq -r '.status // ""' <<<"$overlay")"
			case "$ov_status" in
				starting|running) state="installing" ;;
				failed) state="failed" ;;
			esac
		fi

		# Secret-field presence is derived from state on jq STDIN — the secret
		# VALUES never travel via argv (where /proc/<pid>/cmdline would expose
		# them). Only the non-secret field NAMES go through --arg.
		local secrets_present_json
		secrets_present_json="$(jq -c --arg secrets "$AGG_SECRET_FIELDS" \
			'((.fields // {}) | if type == "object" then . else {} end) as $f
			 | ($secrets | split(" ") | map(select(length > 0)))
			 | [ .[] | select( ($f[.] // "") != "" ) ]' <<<"$raw")"

		local configured="false"
		if [[ "$enabled" == "true" ]] || (( $(jq 'length' <<<"$secrets_present_json") > 0 )); then
			configured="true"
		fi

		jq -nc \
			--arg id "$AGG_ID" \
			--arg name "$AGG_DISPLAY_NAME" \
			--arg acquire "$AGG_ACQUIRE_METHOD" \
			--arg unit "$AGG_SERVICE_UNIT" \
			--arg state "$state" \
			--argjson enabled "$enabled" \
			--argjson configured "$configured" \
			--argjson available "$available" \
			--arg reason "$reason" \
			--argjson mlat_capable "$AGG_MLAT_CAPABLE" \
			--argjson mlat_default "$AGG_MLAT_DEFAULT" \
			--argjson conf_mlat "$mlat_enabled" \
			--argjson fields "$AGG_FIELDS_JSON" \
			--argjson secrets_present "$secrets_present_json" \
			--argjson decoder "$decoder_json" \
			--arg claim "$AGG_CLAIM_URL" \
			--argjson overlay "$ov_json" \
			'{
				id: $id, display_name: $name, acquire_method: $acquire, service_unit: $unit,
				state: $state, enabled: $enabled, configured: $configured,
				available: $available, unavailable_reason: $reason,
				mlat_capable: $mlat_capable, mlat_default: $mlat_default,
				configured_mlat_enabled: $conf_mlat, effective_mlat_enabled: $conf_mlat,
				config_drift: false, fields: $fields, secret_fields_present: $secrets_present,
				decoder_reachable: $decoder, claim_url: $claim
			 }
			 | (if .unavailable_reason == "" then del(.unavailable_reason) else . end)
			 | (if .claim_url == "" then del(.claim_url) else . end)
			 | (if $overlay != null
			    then .enable = ($overlay | {status, step, request_id}
			         + (if .error_code then {error_code} else {} end)
			         + (if .message then {message} else {} end))
			    else . end)'
	)
}

cmd_status() {
	local decoder_json="false"
	if _decoder_reachable; then decoder_json="true"; fi

	local objs=() f obj
	if [[ -d "$AGG_DESC_DIR" ]]; then
		for f in "$AGG_DESC_DIR"/*.desc; do
			[[ -e "$f" ]] || continue
			if ! obj="$(_adapter_json "$f" "$decoder_json")"; then
				# A malformed descriptor is a ship bug, not a runtime condition:
				# fail loud instead of returning a partial/empty success.
				_emit_error state_error "aggregator descriptor failed: $(basename "$f")"
				exit 3
			fi
			objs+=("$obj")
		done
	fi

	local body
	if (( ${#objs[@]} == 0 )); then
		body="$(jq -nc --argjson pv "$AGG_PROTOCOL_VERSION" '{protocol_version:$pv, aggregators:[]}')"
	else
		body="$(printf '%s\n' "${objs[@]}" | jq -sc \
			--argjson pv "$AGG_PROTOCOL_VERSION" '{protocol_version:$pv, aggregators:.}')"
	fi
	_emit_json "$body"
}

# --- mutating verbs --------------------------------------------------------

# _worker_progress <step>: in worker mode, advance the progress overlay to a
# new phase (status stays "running"). A no-op outside the worker.
_worker_progress() {
	(( WORKER_MODE == 1 )) || return 0
	WORKER_STEP="$1"
	_write_enable_state running
}

_emit_ok() {
	# $1 = id, $2 = optional extra-fields JSON object (default {})
	local id="$1" extra="${2-}" body
	# In worker mode there is no HTTP caller: record success in the async
	# progress overlay (status:"done") instead of an envelope on stdout.
	if (( WORKER_MODE == 1 )); then
		WORKER_STEP="done"
		_write_enable_state "done"
		_emitted=1
		return
	fi
	[[ -n "$extra" ]] || extra='{}'
	if ! body="$(jq -nc --argjson pv "$AGG_PROTOCOL_VERSION" --arg id "$id" --argjson x "$extra" \
		'{protocol_version:$pv, result:"ok", id:$id} + $x')"; then
		_emit_error state_error "ok-envelope build failed"
		exit 3
	fi
	_emit_json "$body"
}

# _read_request reads the JSON request object from stdin into REQ_JSON. Bad or
# non-object input is a parse_error. Size-capped so a runaway producer can't
# exhaust memory.
REQ_JSON='{}'
_read_request() {
	REQ_JSON="$(head -c "$AGG_STATE_MAX_BYTES" || true)"
	[[ -n "$REQ_JSON" ]] || { _emit_error parse_error "empty request body"; exit 5; }
	# Slurp-validate: exactly one JSON text, and it is an object. (`jq -e
	# 'type==...'` in streaming mode would accept a multi-document body whose
	# last text happens to be an object.)
	jq -e -s 'length == 1 and (.[0] | type == "object")' >/dev/null 2>&1 <<<"$REQ_JSON" \
		|| { _emit_error parse_error "request body must be a single JSON object"; exit 5; }
}

# _request_id validates the adapter id from REQ_JSON into the global REQ_ID. It
# must be called directly (NOT in a command substitution): on an unknown id it
# emits not_found and exits the process — an exit inside $(...) would only kill
# the subshell and leak the error JSON into the caller's capture. The id must
# be a registered adapter (a descriptor file exists) — the security gate before
# any path interpolation or systemd call.
REQ_ID=""
_request_id() {
	REQ_ID="$(jq -r '.id // ""' <<<"$REQ_JSON")"
	[[ "$REQ_ID" =~ $AGG_ID_RE && -f "$AGG_DESC_DIR/$REQ_ID.desc" ]] \
		|| { _emit_error not_found "unknown aggregator id"; exit 2; }
}

# _descriptor_unit echoes the systemd unit for a (validated) adapter id.
_descriptor_unit() {
	local id="$1"
	(
		AGG_SERVICE_UNIT=""
		# shellcheck source=/dev/null
		source "$AGG_DESC_DIR/$id.desc"
		printf '%s' "$AGG_SERVICE_UNIT"
	)
}

# _acquire_lock takes the process-wide aggregator lock so a concurrent
# mutation (or a webconfig restart racing the CLI) cannot interleave with a
# state write. fd 9 stays open for the process lifetime; the lock releases on
# exit.
_acquire_lock() {
	mkdir -p "$(dirname "$AGG_LOCK")" 2>/dev/null || true
	exec 9>"$AGG_LOCK" || { _emit_error state_error "cannot open lock $AGG_LOCK"; exit 3; }
	flock -w "$AGG_LOCK_TIMEOUT" 9 \
		|| { _emit_error lock_timeout "another aggregator operation is in progress"; exit 4; }
}

# _load_state echoes the persisted state object for id. An ABSENT file is {}
# (a fresh adapter); a PRESENT-but-corrupt/wrong-schema file returns non-zero
# so a mutation refuses to blindly overwrite the operator's prior config
# (reset is the recovery path). Slurp-validated to a single object.
_load_state() {
	local id="$1" raw
	local path="$AGG_STATE_DIR/$id.json"
	[[ -f "$path" ]] || { printf '{}'; return 0; }
	raw="$(head -c "$AGG_STATE_MAX_BYTES" "$path" 2>/dev/null || true)"
	if jq -e -s 'length == 1 and (.[0] | type == "object" and ((.schema_version // 0) <= '"$AGG_STATE_SCHEMA_VERSION"'))' \
		>/dev/null 2>&1 <<<"$raw"; then
		printf '%s' "$raw"
		return 0
	fi
	return 1
}

# _write_state atomically writes the state object for id at mode 0600.
_write_state() {
	local id="$1" json="$2" dir="$AGG_STATE_DIR" tmp
	install -d -m 0750 "$dir" 2>/dev/null || true
	tmp="$(mktemp "$dir/.$id.XXXXXX")" || { _emit_error state_error "mktemp failed in $dir"; exit 3; }
	# Each filesystem step is checked so an ENOSPC/EIO/RO-fs failure emits a
	# specific envelope and cleans up the temp file rather than relying on the
	# generic EXIT-trap fallback.
	if ! { printf '%s\n' "$json" >"$tmp" && chmod 0600 "$tmp" && mv -f "$tmp" "$dir/$id.json"; }; then
		rm -f -- "$tmp"
		_emit_error state_error "failed to write state for $id"
		exit 3
	fi
}

# cmd_set merges mlat_enabled / fields into an adapter's state. Service
# reconciliation (restart + verify) lands with the enable path.
cmd_set() {
	_read_request
	_request_id; local id="$REQ_ID"
	# mlat_enabled, when present, must be a literal boolean.
	if jq -e 'has("mlat_enabled") and (.mlat_enabled | type != "boolean")' \
		>/dev/null 2>&1 <<<"$REQ_JSON"; then
		_emit_error rejected "mlat_enabled must be a boolean"; exit 2
	fi
	# fields, when present, must be an object.
	if jq -e 'has("fields") and (.fields | type != "object")' >/dev/null 2>&1 <<<"$REQ_JSON"; then
		_emit_error rejected "fields must be an object"; exit 2
	fi
	_acquire_lock
	if _enable_in_progress; then
		_emit_error lock_timeout "an enable is in progress; try again shortly"; exit 4
	fi
	local cur merged
	cur="$(_load_state "$id")" \
		|| { _emit_error state_error "existing state for $id is unreadable; reset to clear"; exit 3; }
	merged="$(jq -nc \
		--argjson cur "$cur" --argjson req "$REQ_JSON" --argjson sv "$AGG_STATE_SCHEMA_VERSION" \
		'$cur
		 | .schema_version = $sv
		 | (if $req | has("mlat_enabled") then .mlat_enabled = $req.mlat_enabled else . end)
		 | (if $req | has("fields")
		    then .fields = (((.fields // {}) | if type == "object" then . else {} end) + $req.fields)
		    else . end)')"
	_write_state "$id" "$merged"
	_clear_enable_state "$id"
	_emit_ok "$id"
}

# cmd_disable stops + disables the adapter service and flags enabled=false,
# keeping the installed binary/config so a re-enable needs no re-acquire.
cmd_disable() {
	_read_request
	_request_id; local id="$REQ_ID"
	_acquire_lock
	if _enable_in_progress; then
		_emit_error lock_timeout "an enable is in progress; try again shortly"; exit 4
	fi
	# Validate state + descriptor BEFORE the systemctl side effect so a corrupt
	# state fails fast with no half-applied change.
	local cur unit next
	cur="$(_load_state "$id")" \
		|| { _emit_error state_error "existing state for $id is unreadable; reset to clear"; exit 3; }
	if ! unit="$(_descriptor_unit "$id")"; then
		_emit_error state_error "descriptor read failed for $id"; exit 3
	fi
	if [[ -n "$unit" ]]; then
		"$AGG_SYSTEMCTL" disable --now "$unit" >/dev/null 2>&1 || true
	fi
	next="$(jq -nc --argjson cur "$cur" --argjson sv "$AGG_STATE_SCHEMA_VERSION" \
		'$cur | .schema_version = $sv | .enabled = false')"
	_write_state "$id" "$next"
	_clear_enable_state "$id"
	_emit_ok "$id"
}

# cmd_reset is the full teardown: stop+disable the unit, drop our state and the
# on-demand install dir. Vendor-specific teardown (apt purge, keyring/source
# removal, decoder-unit unmask) is layered in by the per-adapter acquire path.
cmd_reset() {
	_read_request
	_request_id; local id="$REQ_ID"
	# Guard the recursive delete: an absolute, non-root install root plus a
	# registry-validated id (AGG_ID_RE forbids leading dash / slash / dots).
	[[ "$AGG_INSTALL_ROOT" == /* && "$AGG_INSTALL_ROOT" != "/" ]] \
		|| { _emit_error state_error "unsafe install root"; exit 3; }
	_acquire_lock
	if _enable_in_progress; then
		_emit_error lock_timeout "an enable is in progress; try again shortly"; exit 4
	fi
	local unit
	if ! unit="$(_descriptor_unit "$id")"; then
		_emit_error state_error "descriptor read failed for $id"; exit 3
	fi
	if [[ -n "$unit" ]]; then
		"$AGG_SYSTEMCTL" disable --now "$unit" >/dev/null 2>&1 || true
	fi
	rm -f -- "$AGG_STATE_DIR/$id.json"
	rm -rf -- "${AGG_INSTALL_ROOT:?}/$id"
	_clear_enable_state "$id"
	_emit_ok "$id"
}

# --- enable: on-demand vendor acquire + service start ----------------------

_valid_email() {
	[[ "$1" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]]
}

# _valid_geo lat lon alt(metres): numeric + sane ranges.
_valid_geo() {
	local lat="$1" lon="$2" alt="$3"
	[[ "$lat" =~ ^-?[0-9]+(\.[0-9]+)?$ && "$lon" =~ ^-?[0-9]+(\.[0-9]+)?$ && "$alt" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || return 1
	awk -v la="$lat" -v lo="$lon" -v al="$alt" \
		'BEGIN { exit !(la >= -90 && la <= 90 && lo >= -180 && lo <= 180 && al >= -500 && al <= 12000) }'
}

# fr24 sharing keys are short alphanumerics. Validating before a key reaches an
# ini line or the state file blocks ini-injection (a key bearing a quote or
# newline) on both the provided-key and signup-extracted paths.
_valid_fr24_key() {
	[[ "$1" =~ ^[A-Za-z0-9]{6,40}$ ]]
}

# _fr24_acquire_binary <url> <sha256> <dest>: download the pinned fr24feed .deb,
# verify its sha256 (a root-executed binary), extract just the binary (NOT the
# vendor cron-updater or unit), and install it at <dest>.
# Returns: 0 ok, 1 download/integrity failure (network class), 2 local fs/tool
# failure. Test seam: AGG_FR24_ACQUIRE_OVERRIDE <dest>.
_fr24_acquire_binary() {
	local url="$1" sha="$2" dest="$3"
	if [[ -n "${AGG_FR24_ACQUIRE_OVERRIDE:-}" ]]; then
		"$AGG_FR24_ACQUIRE_OVERRIDE" "$dest"; return
	fi
	[[ "$url" == https://* ]] || return 1
	local tmp deb got src
	tmp="$(mktemp -d)" || return 2
	deb="$tmp/fr24.deb"
	if ! curl -fsSL --max-time 120 -o "$deb" "$url"; then rm -rf "$tmp"; return 1; fi
	got="$(sha256sum "$deb" 2>/dev/null | cut -d' ' -f1)"
	printf 'apl-aggregator: fetched %s sha256=%s\n' "$url" "$got" >&2
	if [[ -z "$got" || ( -n "$sha" && "$got" != "$sha" ) ]]; then rm -rf "$tmp"; return 1; fi
	if ! dpkg -x "$deb" "$tmp/root" 2>/dev/null; then rm -rf "$tmp"; return 2; fi
	src="$tmp/root/usr/bin/fr24feed"
	[[ -f "$src" ]] || { rm -rf "$tmp"; return 1; }
	install -D -m 0755 "$src" "$dest" || { rm -rf "$tmp"; return 2; }
	rm -rf "$tmp"
}

# _fr24_write_ini <ini> <key>: configure fr24feed as a BEAST-TCP consumer of
# the local decoder with the operator's sharing key (MLAT off, per the
# adapter's FR24-MLAT-default-off contract).
_fr24_write_ini() {
	local ini="$1" key="$2" tmp
	tmp="$(mktemp "${ini}.XXXXXX")" || return 1
	if ! cat >"$tmp" <<EOF
receiver="beast-tcp"
host="127.0.0.1:30005"
fr24key="$key"
bs="no"
raw="no"
mlat="no"
mlat-without-gps="no"
EOF
	then rm -f -- "$tmp"; return 1; fi
	if ! { chmod 0640 "$tmp" && mv -f -- "$tmp" "$ini"; }; then
		rm -f -- "$tmp"; return 1
	fi
}

# _fr24_read_key <ini>: extract the quoted fr24key value (empty if absent or
# malformed — strict, so a bare `fr24key=` never yields a bogus non-empty key).
_fr24_read_key() {
	sed -n 's/^fr24key="\([^"]*\)".*/\1/p' "$1" 2>/dev/null | head -1
}

# _fr24_finalize_perms <ini>: hand the ini + its dir to the service account if
# it exists (created by the image build); on CI / older images it stays root.
_fr24_finalize_perms() {
	local ini="$1"
	id -u airplanes-aggregator >/dev/null 2>&1 || return 0
	chown airplanes-aggregator:airplanes-aggregator "$ini" 2>/dev/null || true
	chown airplanes-aggregator:airplanes-aggregator "$(dirname "$ini")" 2>/dev/null || true
}

# _fr24_signup <bin> <ini> <email> <lat> <lon> <alt_m>: mint a fresh sharing
# key by driving `fr24feed --signup --adsb` via piped stdin (validated on a
# feeder: the wizard reads stdin, no tty/expect needed). Answer order matches
# the wizard. Test seam: AGG_FR24_SIGNUP_OVERRIDE <ini> <email>.
_fr24_signup() {
	local bin="$1" ini="$2" email="$3" lat="$4" lon="$5" alt_m="$6" alt_ft
	if [[ -n "${AGG_FR24_SIGNUP_OVERRIDE:-}" ]]; then
		"$AGG_FR24_SIGNUP_OVERRIDE" "$ini" "$email"
	else
		alt_ft="$(awk -v m="$alt_m" 'BEGIN { printf "%d", m * 82 / 25 }')"
		printf '%s\n' \
			"$email" "" "no" "" "$lat" "$lon" "$alt_ft" "yes" "no" \
			"4" "1" "127.0.0.1" "30005" "no" "no" "0" \
			| timeout "${AGG_FR24_SIGNUP_TIMEOUT:-180}" "$bin" --signup --adsb --config-file="$ini" >/dev/null 2>&1 || true
	fi
	# Success is judged by a key landing in the ini, not the wizard's exit code.
	[[ -f "$ini" ]] && grep -qs '^fr24key' "$ini"
}

_enable_fr24() {
	local email key lat lon alt fields cur
	# Existing state fields (e.g. seeded by `import`) are the base; request
	# fields override. This lets a restored key/email be reused without
	# re-entry. Both inputs go via jq stdin so secrets never touch argv. A
	# present-but-corrupt state fails loud rather than being silently dropped.
	cur="$(_load_state "fr24" 2>/dev/null)" \
		|| { _emit_error state_error "existing fr24 state is unreadable; reset to clear"; exit 3; }
	fields="$(printf '%s\n%s\n' "$cur" "$REQ_JSON" \
		| jq -cn 'input as $cur | input as $req | (($cur.fields // {}) + ($req.fields // {}))')"
	email="$(jq -r '.email // ""' <<<"$fields")"
	key="$(jq -r '.sharing_key // ""' <<<"$fields")"
	lat="$(jq -r 'if has("lat") then .lat else "" end' <<<"$REQ_JSON")"
	lon="$(jq -r 'if has("lon") then .lon else "" end' <<<"$REQ_JSON")"
	alt="$(jq -r 'if has("alt") then .alt else "" end' <<<"$REQ_JSON")"

	_valid_email "$email" || { _emit_error rejected "a valid email address is required"; exit 2; }
	_valid_geo "$lat" "$lon" "$alt" || { _emit_error rejected "valid latitude, longitude and altitude are required"; exit 2; }
	[[ -z "$key" ]] || _valid_fr24_key "$key" || { _emit_error rejected "invalid sharing key format"; exit 2; }
	_decoder_reachable || { _emit_error decoder_unavailable "local decoder 127.0.0.1:30005 is not reachable"; exit 2; }

	# Pinned vendor URL + checksum from the (trusted) descriptor, captured in a
	# subshell so descriptor sourcing cannot clobber locals or write to stdout.
	local desc_out url sha
	# shellcheck source=/dev/null
	desc_out="$( source "$AGG_DESC_DIR/fr24.desc" >/dev/null 2>&1; printf '%s\n%s\n' "${AGG_FR24_DEB_URL:-}" "${AGG_FR24_DEB_SHA256:-}" )"
	url="$(sed -n 1p <<<"$desc_out")"
	sha="$(sed -n 2p <<<"$desc_out")"

	local bin ini
	bin="${AGG_FR24_BIN:-$AGG_INSTALL_ROOT/fr24/fr24feed}"
	ini="${AGG_FR24_INI:-$AGG_STATE_HOME/fr24/fr24feed.ini}"

	local rc=0
	_worker_progress acquiring
	_fr24_acquire_binary "$url" "$sha" "$bin" || rc=$?
	case "$rc" in
		0) ;;
		2) _emit_error state_error "failed to install fr24feed locally"; exit 3 ;;
		*) _emit_error acquire_failed "could not download or verify fr24feed (check connectivity)"; exit 2 ;;
	esac

	_worker_progress configuring
	install -d -m 0750 "$(dirname "$ini")" 2>/dev/null || true
	if [[ -n "$key" ]]; then
		_fr24_write_ini "$ini" "$key" || { _emit_error state_error "failed to write fr24feed.ini"; exit 3; }
	else
		if ! _fr24_signup "$bin" "$ini" "$email" "$lat" "$lon" "$alt"; then
			_emit_error signup_failed "fr24 signup did not return a sharing key"; exit 2
		fi
		key="$(_fr24_read_key "$ini")"
		_valid_fr24_key "$key" || { _emit_error signup_failed "fr24 signup did not return a usable key"; exit 2; }
	fi
	_fr24_finalize_perms "$ini"

	# Persist state BEFORE starting the unit, so a start failure leaves a
	# visible enabled+stopped record rather than a running service with no
	# state. Secrets travel via stdin to jq, never on its argv.
	local state
	state="$(printf '%s\n%s\n' "$email" "$key" | jq -Rn --argjson sv "$AGG_STATE_SCHEMA_VERSION" \
		'(input) as $email | (input) as $key
		 | {schema_version:$sv, enabled:true, mlat_enabled:false, fields:{email:$email, sharing_key:$key}}')"
	_write_state "fr24" "$state"

	_worker_progress starting-service
	if ! "$AGG_SYSTEMCTL" enable --now "airplanes-aggregator@fr24.service" >/dev/null 2>&1; then
		_emit_error state_error "fr24 configured but the service failed to start"; exit 3
	fi
	_emit_ok "fr24" '{"sharing_key_present":true}'
}

# _fr24_validate_sync: the fast synchronous validation cmd_enable runs before
# launching the worker. Mirrors the head of _enable_fr24 — load + merge state
# (so a restored email/key counts), then require a valid email/geo, a valid key
# format if one is present, and a reachable decoder. Emits the error envelope +
# exits on failure, so a bad request fails immediately instead of after a 202.
_fr24_validate_sync() {
	local email key lat lon alt fields cur
	cur="$(_load_state "fr24" 2>/dev/null)" \
		|| { _emit_error state_error "existing fr24 state is unreadable; reset to clear"; exit 3; }
	fields="$(printf '%s\n%s\n' "$cur" "$REQ_JSON" \
		| jq -cn 'input as $cur | input as $req | (($cur.fields // {}) + ($req.fields // {}))')"
	email="$(jq -r '.email // ""' <<<"$fields")"
	key="$(jq -r '.sharing_key // ""' <<<"$fields")"
	lat="$(jq -r 'if has("lat") then .lat else "" end' <<<"$REQ_JSON")"
	lon="$(jq -r 'if has("lon") then .lon else "" end' <<<"$REQ_JSON")"
	alt="$(jq -r 'if has("alt") then .alt else "" end' <<<"$REQ_JSON")"
	_valid_email "$email" || { _emit_error rejected "a valid email address is required"; exit 2; }
	_valid_geo "$lat" "$lon" "$alt" || { _emit_error rejected "valid latitude, longitude and altitude are required"; exit 2; }
	[[ -z "$key" ]] || _valid_fr24_key "$key" || { _emit_error rejected "invalid sharing key format"; exit 2; }
	_decoder_reachable || { _emit_error decoder_unavailable "local decoder 127.0.0.1:30005 is not reachable"; exit 2; }
}

# _gen_reqid: a filesystem- and argv-safe request id for one enable run.
_gen_reqid() {
	local u
	u="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || true)"
	[[ -n "$u" ]] || u="$(date +%s%N 2>/dev/null || echo 0)$$$RANDOM"
	printf '%s' "${u//[^a-z0-9-]/}"
}

# _spool_request <id> <reqid>: persist the (already-validated, single-object)
# REQ_JSON — which carries secrets — to a 0600 root file under a 0700 dir, so
# the detached worker can read it by id. Atomic temp+rename.
_spool_request() {
	local reqid="$1" tmp path="$AGG_REQ_DIR/$1.json"
	( umask 077; install -d -m 0700 "$AGG_REQ_DIR" ) 2>/dev/null || true
	tmp="$(mktemp "$AGG_REQ_DIR/.$reqid.XXXXXX" 2>/dev/null)" || return 1
	if printf '%s\n' "$REQ_JSON" >"$tmp" 2>/dev/null && chmod 0600 "$tmp" 2>/dev/null; then
		mv -f "$tmp" "$path" 2>/dev/null || { rm -f -- "$tmp"; return 1; }
	else
		rm -f -- "$tmp"; return 1
	fi
}

_rm_spool() { rm -f -- "$AGG_REQ_DIR/$1.json" 2>/dev/null || true; }

# _enable_in_progress: is an enable worker running (or just launched)? True if
# the enable unit is active/activating, or a running/starting overlay was
# published within the grace window (the worker hasn't become visible to
# systemd yet). A stale overlay past the grace window is NOT in-progress.
_enable_in_progress() {
	local svc
	svc="$(_service_state "$AGG_ENABLE_UNIT")"
	[[ "$svc" == "active" || "$svc" == "activating" ]] && return 0
	[[ -f "$AGG_ENABLE_STATE" ]] || return 1
	local raw st started age
	raw="$(head -c "$AGG_STATE_MAX_BYTES" "$AGG_ENABLE_STATE" 2>/dev/null || true)"
	st="$(jq -r '.status // ""' <<<"$raw" 2>/dev/null || true)"
	[[ "$st" == "running" || "$st" == "starting" ]] || return 1
	started="$(jq -r '.started_at // 0' <<<"$raw" 2>/dev/null || echo 0)"
	[[ "$started" =~ ^[0-9]+$ ]] || started=0
	age=$(( $(date +%s 2>/dev/null || echo 0) - started ))
	(( started > 0 && age <= AGG_ENABLE_GRACE ))
}

# _emit_accepted <id> <reqid>: the fire-and-forget enable response.
_emit_accepted() {
	local id="$1" reqid="$2" body
	if ! body="$(jq -nc --argjson pv "$AGG_PROTOCOL_VERSION" --arg id "$id" --arg rid "$reqid" \
		'{protocol_version:$pv, result:"accepted", step:"starting", id:$id, request_id:$rid}')"; then
		_emit_error state_error "accepted-envelope build failed"; exit 3
	fi
	_emit_json "$body"
}

# cmd_enable validates synchronously, then launches the slow vendor acquire as a
# detached transient unit (systemd-run) and returns {result:"accepted"} in <1s.
# The flock guards validation + spool; it is released before the worker is
# launched (the worker re-acquires it for its whole transaction). One enable at
# a time is enforced by _enable_in_progress + the fixed unit name.
cmd_enable() {
	_read_request
	_request_id; local id="$REQ_ID"
	_acquire_lock
	if _enable_in_progress; then
		_emit_error lock_timeout "an enable is already in progress; try again shortly"; exit 4
	fi
	case "$id" in
		fr24) _fr24_validate_sync ;;
		*) _emit_error rejected "enable is not yet supported for $id"; exit 2 ;;
	esac

	local reqid; reqid="$(_gen_reqid)"
	[[ -n "$reqid" ]] || { _emit_error state_error "could not generate a request id"; exit 3; }
	WORKER_ID="$id"; WORKER_REQID="$reqid"
	WORKER_STARTED="$(date +%s 2>/dev/null || echo 0)"
	# We hold the lock and no enable is in progress, so any spool file still on
	# disk is orphaned (a prior worker that died, or a launch that never execed
	# its worker). Sweep before spooling so a never-consumed secret can't
	# accumulate in /run across enables.
	rm -f -- "$AGG_REQ_DIR"/*.json 2>/dev/null || true
	_spool_request "$reqid" || { _emit_error state_error "failed to spool enable request"; exit 3; }

	# Clear any stale terminal unit so the fixed systemd-run name is free, then
	# publish the running overlay BEFORE launch — the grace window in
	# _enable_overlay covers the launch-to-active latency so this can't read as a
	# dead worker.
	"$AGG_SYSTEMCTL" reset-failed "$AGG_ENABLE_UNIT" >/dev/null 2>&1 || true
	WORKER_STEP="starting"; _write_enable_state running
	exec 9>&-  # release the flock so the worker can take it

	# Pass both the request id and the adapter id: the id lets the worker stamp
	# a correctly-attributed progress overlay even if it dies before reading the
	# spool (the id is not a secret; only reqid indexes the secret payload).
	if ! "$AGG_SYSTEMD_RUN" --unit="$AGG_ENABLE_UNIT" --collect \
		"$AGG_SELF" __enable-worker "$reqid" "$id" >/dev/null 2>&1; then
		# Launch failed (e.g. the unit already exists → a racing enable won). Roll
		# back ONLY our own overlay (reqid-matched) + spool and report
		# transient-busy.
		_rm_spool "$reqid"
		_clear_enable_state "$id" "$reqid"
		_emit_error lock_timeout "could not launch enable (another may be in progress)"; exit 4
	fi
	_emit_accepted "$id" "$reqid"
}

# cmd_enable_worker is the detached worker (systemd-run target, root). It is not
# a sudoers verb — webconfig can only invoke `enable --json`. It reads the
# spooled request, unlinks the secret spool immediately, then runs the adapter
# acquire under the lock, reporting progress through the overlay.
cmd_enable_worker() {
	local reqid="$1" id="$2"
	WORKER_MODE=1
	WORKER_REQID="$reqid"
	WORKER_STARTED="$(date +%s 2>/dev/null || echo 0)"
	# Set WORKER_ID up front (from the trusted argv, not the spool) so EVERY
	# failure path below — including a missing/corrupt spool — writes a progress
	# overlay attributed to the right adapter, not an unattached id:"" record
	# that status would ignore.
	[[ "$reqid" =~ ^[a-z0-9-]+$ ]] || { _emit_error usage_error "invalid worker request id"; exit 5; }
	[[ "$id" =~ $AGG_ID_RE && -f "$AGG_DESC_DIR/$id.desc" ]] || { _emit_error not_found "unknown aggregator id"; exit 2; }
	WORKER_ID="$id"
	local path="$AGG_REQ_DIR/$reqid.json"
	if [[ ! -f "$path" ]]; then
		_emit_error state_error "enable request spool missing"; exit 3
	fi
	# Load into memory, then delete the secret spool BEFORE the slow work so a
	# SIGKILL / RuntimeMaxSec mid-acquire leaves no secret on disk.
	REQ_JSON="$(head -c "$AGG_STATE_MAX_BYTES" "$path" 2>/dev/null || true)"
	_rm_spool "$reqid"
	jq -e -s 'length == 1 and (.[0] | type == "object")' >/dev/null 2>&1 <<<"$REQ_JSON" \
		|| { _emit_error parse_error "spooled request is not a single JSON object"; exit 5; }
	# Defence in depth: the spool's id must match the id we were launched with.
	_request_id
	[[ "$REQ_ID" == "$id" ]] || { _emit_error rejected "spooled request id mismatch"; exit 2; }
	WORKER_STEP="starting"; _write_enable_state running
	_acquire_lock
	case "$REQ_ID" in
		fr24) _enable_fr24 ;;
		*) _emit_error rejected "enable is not yet supported for $REQ_ID"; exit 2 ;;
	esac
}

# --- backup / restore ------------------------------------------------------

# cmd_export emits a backup blob with the recoverable identities (INCLUDING
# secret values) of every adapter that has state. This is the one verb that
# returns secrets — an explicit, session-authenticated backup. jq reads the
# state files directly, so secrets never enter a bash variable or jq argv.
cmd_export() {
	_acquire_lock
	local ids=() files=() f id
	if [[ -d "$AGG_DESC_DIR" ]]; then
		for f in "$AGG_DESC_DIR"/*.desc; do
			[[ -e "$f" ]] || continue
			id="$(basename "$f" .desc)"
			[[ "$id" =~ $AGG_ID_RE && -f "$AGG_STATE_DIR/$id.json" ]] || continue
			# Skip a corrupt/empty/multi-doc state file: only single valid
			# objects are included, keeping the `[inputs]`/ids[] arrays aligned.
			_load_state "$id" >/dev/null 2>&1 || continue
			ids+=("$id"); files+=("$AGG_STATE_DIR/$id.json")
		done
	fi
	local body
	if (( ${#ids[@]} == 0 )); then
		body="$(jq -nc --argjson pv "$AGG_PROTOCOL_VERSION" --argjson sv "$AGG_STATE_SCHEMA_VERSION" \
			'{protocol_version:$pv, result:"ok", kind:"aggregator-backup", schema_version:$sv, aggregators:{}}')" \
			|| { _emit_error state_error "export failed"; exit 3; }
	else
		local ids_json
		ids_json="$(jq -nc --args '$ARGS.positional' "${ids[@]}")"
		body="$(jq -n --argjson pv "$AGG_PROTOCOL_VERSION" --argjson sv "$AGG_STATE_SCHEMA_VERSION" --argjson ids "$ids_json" \
			'[inputs] as $st
			 | {protocol_version:$pv, result:"ok", kind:"aggregator-backup", schema_version:$sv,
			    aggregators: (reduce range(0; ($ids|length)) as $i ({};
			      . + {($ids[$i]): {mlat_enabled: ($st[$i].mlat_enabled // false), fields: ($st[$i].fields // {})}}))}' \
			"${files[@]}")" \
			|| { _emit_error state_error "export failed"; exit 3; }
	fi
	_emit_json "$body"
}

# cmd_import restores identities from a backup blob on stdin. It validates the
# whole blob first (all-or-nothing), refuses to overwrite an ENABLED adapter
# (avoid state/vendor-config split-brain), then seeds each adapter's state with
# enabled=false — a later enable reuses the restored identity. Secrets stay on
# jq stdin throughout.
cmd_import() {
	_read_request
	# Thorough structural validation up front: kind/schema, every adapter key
	# is a syntactically valid id (so the mapfile split below is safe), every
	# value is an object with object fields, boolean mlat, string key, and the
	# fr24 sharing key (if present) matches the key alphabet.
	jq -e --argjson sv "$AGG_STATE_SCHEMA_VERSION" '
		(.kind == "aggregator-backup")
		and ((.schema_version // 0) <= $sv)
		and (.aggregators | type == "object")
		and (.aggregators | keys | all(test("^[a-z0-9][a-z0-9_-]*$")))
		and (.aggregators | to_entries | all(.value as $a
			| ($a | type == "object")
			and (($a.fields // {}) | type == "object")
			and (($a.mlat_enabled // false) | type == "boolean")
			and (($a.fields.sharing_key // "") | type == "string")))
		and ((.aggregators.fr24.fields.sharing_key // "")
			| (. == "" or test("^[A-Za-z0-9]{6,40}$")))
	' >/dev/null 2>&1 <<<"$REQ_JSON" \
		|| { _emit_error parse_error "not a valid aggregator backup"; exit 5; }

	local ids id
	mapfile -t ids < <(jq -r '.aggregators | keys[]' <<<"$REQ_JSON")
	(( ${#ids[@]} > 0 )) || { _emit_error rejected "backup contains no aggregators"; exit 2; }

	_acquire_lock
	if _enable_in_progress; then
		_emit_error lock_timeout "an enable is in progress; try again shortly"; exit 4
	fi
	# Validate against on-device state and pre-build every seeded record BEFORE
	# writing any, so a rejected adapter can't leave a half-applied restore.
	local -a write_ids=() write_states=()
	for id in "${ids[@]}"; do
		[[ -f "$AGG_DESC_DIR/$id.desc" ]] \
			|| { _emit_error rejected "backup references unknown adapter '$id'"; exit 2; }
		local cur
		cur="$(_load_state "$id" 2>/dev/null)" \
			|| { _emit_error state_error "$id state is unreadable; reset to clear"; exit 3; }
		if [[ "$(jq -r '.enabled == true' <<<"$cur")" == "true" ]]; then
			_emit_error rejected "$id is enabled; disable it before importing"; exit 2
		fi
		local seeded
		seeded="$(jq -c --argjson sv "$AGG_STATE_SCHEMA_VERSION" --arg id "$id" \
			'.aggregators[$id] as $a
			 | {schema_version:$sv, enabled:false, mlat_enabled:($a.mlat_enabled // false), fields:($a.fields // {})}' \
			<<<"$REQ_JSON")"
		write_ids+=("$id"); write_states+=("$seeded")
	done
	local i
	for i in "${!write_ids[@]}"; do
		_write_state "${write_ids[$i]}" "${write_states[$i]}"
		# A restored identity supersedes any prior failed-enable overlay.
		_clear_enable_state "${write_ids[$i]}"
	done
	local body
	body="$(jq -nc --argjson pv "$AGG_PROTOCOL_VERSION" --argjson n "${#write_ids[@]}" \
		'{protocol_version:$pv, result:"ok", imported:$n}')"
	_emit_json "$body"
}

# --- dispatch --------------------------------------------------------------

main() {
	command -v jq >/dev/null 2>&1 || { _emit_error state_error "jq is required"; exit 3; }

	# Internal worker mode (not a sudoers verb; launched only by systemd-run as
	# root). Argv is `__enable-worker <request_id> <id>`, no --json.
	if [[ "${1-}" == "__enable-worker" ]]; then
		[[ $# -eq 3 ]] || { _emit_error usage_error "usage: apl-aggregator __enable-worker <request_id> <id>"; exit 5; }
		cmd_enable_worker "$2" "$3"; exit 0
	fi

	if [[ $# -ne 2 || "${2-}" != "--json" ]]; then
		_emit_error usage_error "usage: apl-aggregator {status|list|enable|set|disable|reset|export|import} --json"
		exit 5
	fi
	case "$1" in
		status|list) cmd_status; exit 0 ;;
		enable) cmd_enable; exit 0 ;;
		set) cmd_set; exit 0 ;;
		disable) cmd_disable; exit 0 ;;
		reset) cmd_reset; exit 0 ;;
		export) cmd_export; exit 0 ;;
		import) cmd_import; exit 0 ;;
		*) _emit_error usage_error "unknown verb '$1'; use status|list|enable|set|disable|reset|export|import --json"; exit 5 ;;
	esac
}

main "$@"
